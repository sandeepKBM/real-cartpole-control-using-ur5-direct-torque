<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="real_cartpole">
  <xacro:property name="pi" value="3.1415926535897931"/>

  <material name="black">
    <color rgba="0.1 0.1 0.1 1.0"/>
  </material>
  <material name="blue">
    <color rgba="0.30 0.55 0.75 1.0"/>
  </material>
  <material name="gray">
    <color rgba="0.70 0.70 0.72 1.0"/>
  </material>
  <material name="orange">
    <color rgba="1.0 0.45 0.0 1.0"/>
  </material>

  <link name="world"/>

  <joint name="world_to_base_link" type="fixed">
    <parent link="world"/>
    <child link="base_link"/>
    <origin xyz="0 0 0" rpy="0 0 ${pi}"/>
  </joint>

  <link name="base_link">
    <visual>
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.09" length="0.10"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.09" length="0.10"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
      <mass value="4.0"/>
      <inertia ixx="0.0072" ixy="0.0" ixz="0.0" iyy="0.0072" iyz="0.0" izz="0.0044"/>
    </inertial>
  </link>

  <link name="shoulder_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.075"/>
      </geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.075"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="3.7"/>
      <inertia ixx="0.0103" ixy="0.0" ixz="0.0" iyy="0.0103" iyz="0.0" izz="0.0067"/>
    </inertial>
  </link>

  <joint name="shoulder_pan_joint" type="revolute">
    <parent link="base_link"/>
    <child link="shoulder_link"/>
    <origin xyz="0 0 0.163" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-6.28319" upper="6.28319" effort="150" velocity="1.5"/>
  </joint>

  <link name="upper_arm_link">
    <visual>
      <origin xyz="0 0 0.2125" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.05" length="0.425"/>
      </geometry>
      <material name="gray"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.2125" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.05" length="0.425"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0.2125" rpy="0 0 0"/>
      <mass value="8.393"/>
      <inertia ixx="0.1339" ixy="0.0" ixz="0.0" iyy="0.1339" iyz="0.0" izz="0.0151"/>
    </inertial>
  </link>

  <joint name="shoulder_lift_joint" type="revolute">
    <parent link="shoulder_link"/>
    <child link="upper_arm_link"/>
    <origin xyz="0 0.138 0" rpy="0 ${pi / 2.0} 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-6.28319" upper="6.28319" effort="150" velocity="1.5"/>
  </joint>

  <link name="forearm_link">
    <visual>
      <origin xyz="0 0 0.196" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.045" length="0.392"/>
      </geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.196" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.045" length="0.392"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0.196" rpy="0 0 0"/>
      <mass value="2.275"/>
      <inertia ixx="0.0312" ixy="0.0" ixz="0.0" iyy="0.0312" iyz="0.0" izz="0.0041"/>
    </inertial>
  </link>

  <joint name="elbow_joint" type="revolute">
    <parent link="upper_arm_link"/>
    <child link="forearm_link"/>
    <origin xyz="0 -0.131 0.425" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-3.1415" upper="3.1415" effort="150" velocity="1.5"/>
  </joint>

  <link name="wrist_1_link">
    <visual>
      <origin xyz="0 0 0.07" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.04" length="0.14"/>
      </geometry>
      <material name="gray"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.07" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.04" length="0.14"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0.127 0" rpy="0 0 0"/>
      <mass value="1.219"/>
      <inertia ixx="0.00256" ixy="0.0" ixz="0.0" iyy="0.00256" iyz="0.0" izz="0.00219"/>
    </inertial>
  </link>

  <joint name="wrist_1_joint" type="revolute">
    <parent link="forearm_link"/>
    <child link="wrist_1_link"/>
    <origin xyz="0 0 0.392" rpy="0 ${pi / 2.0} 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-6.28319" upper="6.28319" effort="28" velocity="2.0"/>
  </joint>

  <link name="wrist_2_link">
    <visual>
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.035" length="0.10"/>
      </geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.035" length="0.10"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
      <mass value="1.219"/>
      <inertia ixx="0.00256" ixy="0.0" ixz="0.0" iyy="0.00256" iyz="0.0" izz="0.00219"/>
    </inertial>
  </link>

  <joint name="wrist_2_joint" type="revolute">
    <parent link="wrist_1_link"/>
    <child link="wrist_2_link"/>
    <origin xyz="0 0.127 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-6.28319" upper="6.28319" effort="28" velocity="2.0"/>
  </joint>

  <link name="wrist_3_link">
    <visual>
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.03" length="0.10"/>
      </geometry>
      <material name="gray"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.03" length="0.10"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0.077 0" rpy="0 0 0"/>
      <mass value="0.1889"/>
      <inertia ixx="0.000132" ixy="0.0" ixz="0.0" iyy="0.000099" iyz="0.0" izz="0.000099"/>
    </inertial>
  </link>

  <joint name="wrist_3_joint" type="revolute">
    <parent link="wrist_2_link"/>
    <child link="wrist_3_link"/>
    <origin xyz="0 0 0.1" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-6.28319" upper="6.28319" effort="28" velocity="2.0"/>
  </joint>

  <link name="attachment_site_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.02"/>
      </geometry>
      <material name="orange"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.02"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.02"/>
      <inertia ixx="1e-5" ixy="0.0" ixz="0.0" iyy="1e-5" iyz="0.0" izz="1e-5"/>
    </inertial>
  </link>

  <joint name="attachment_site_joint" type="fixed">
    <parent link="wrist_3_link"/>
    <child link="attachment_site_link"/>
    <origin xyz="0 0.1 0" rpy="-${pi / 2.0} 0 0"/>
  </joint>

  <ros2_control name="UR5eMockSystem" type="system">
    <hardware>
      <plugin>mock_components/GenericSystem</plugin>
    </hardware>

    <joint name="shoulder_pan_joint">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="shoulder_lift_joint">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="elbow_joint">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="wrist_1_joint">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="wrist_2_joint">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="wrist_3_joint">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
  </ros2_control>
</robot>
